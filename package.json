{
  "name": "flowguard",
  "version": "0.1.0",
  "description": "Resilient workflow orchestration for Node, browser and React Native — sagas, idempotency, retry with backoff, compensation, timeout and pluggable storage. Zero runtime dependencies.",
  "keywords": [
    "saga",
    "workflow",
    "orchestration",
    "idempotency",
    "retry",
    "backoff",
    "compensation",
    "resilience",
    "transactional",
    "typescript"
  ],
  "license": "MIT",
  "author": "elvesdev@proton.me",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./storage/memory": {
      "types": "./dist/storage/memory.d.ts",
      "import": "./dist/storage/memory.js",
      "require": "./dist/storage/memory.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
